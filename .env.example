# Copy this file to .env for local overrides.
# Keep .env untracked so each machine can choose its own bind addresses and ports.

# Use 127.0.0.1 when exposing through a local reverse proxy such as Caddy.
FRONTEND_BIND_ADDRESS=127.0.0.1
FRONTEND_PORT=5173
BACKEND_BIND_ADDRESS=127.0.0.1
BACKEND_PORT=8080
POSTGRES_BIND_ADDRESS=127.0.0.1

POSTGRES_DB=dxnavigator
POSTGRES_USER=dxnavigator
POSTGRES_PASSWORD=dxnavigator_dev_password

# Development is the default compose mode. The production compose overlay sets this to Production.
ASPNETCORE_ENVIRONMENT=Development

# Temporary until EF migrations replace development-time schema creation.
DATABASE_ENSURE_CREATED=true

# Optional: configure these when enabling Google sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
